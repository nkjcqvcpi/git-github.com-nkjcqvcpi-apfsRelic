{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "apfsRelic",
  "version": "0.1.0",
  "identifier": "com.apfsrelic.explorer",
  "build": {
    "beforeDevCommand": { "cwd": "../../frontend", "script": "pnpm dev" },
    "beforeBuildCommand": { "cwd": "../../frontend", "script": "pnpm build" },
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "apfsRelic file explorer",
        "width": 1040,
        "height": 760,
        "minWidth": 640,
        "minHeight": 420,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../frontend/icons/32x32.png",
      "../../frontend/icons/128x128.png",
      "../../frontend/icons/128x128@2x.png",
      "../../frontend/icons/icon.icns",
      "../../frontend/icons/icon.ico"
    ]
  }
}
